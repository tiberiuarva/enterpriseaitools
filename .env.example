# Site URL used for canonical links and OG metadata.
# Set to your production domain. Defaults to https://enterpriseai.tools
# NEXT_PUBLIC_SITE_URL=https://enterpriseai.tools

# Base path prefix for the static export.
# Set to empty string for root deployment, or a path like /enterpriseai-tools
# for subdirectory hosting. Defaults to /enterpriseai-tools
# NEXT_PUBLIC_BASE_PATH=/enterpriseai-tools

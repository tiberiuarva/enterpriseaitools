{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["*.svg", "*.png", "*.ico", "*.json", "*.txt", "*.xml", "/logos/*", "/_next/*"]
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=0, must-revalidate"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".svg": "image/svg+xml"
  }
}
